{
  "name": "@mordech/web-components",
  "version": "0.37.0",
  "type": "module",
  "main": "dist/index.cjs",
  "license": "MIT",
  "author": "Elad Mordechai Mizrahi",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "test": "vitest run --coverage --passWithNoTests",
    "storybook": "storybook dev -p 4600 -c .storybook",
    "build-storybook": "storybook build -o storybook-static -c .storybook",
    "visual": "loki test --reactUri file:./storybook-static",
    "visual:ci": "loki test --requireReference --reactUri file:./storybook-static",
    "visual:approve": "loki approve",
    "lint": "eslint src",
    "lint:css": "stylelint 'src/**/*.{ts,css}'",
    "prepare": "yarn build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mordech/mordech-projects.git",
    "directory": "packages/web-components",
    "homepage": "https://github.com/Mordech/mordech-projects/tree/main/packages/web-components#readme"
  },
  "exports": {
    "./*": {
      "default": "./dist/components/*.js",
      "types": "./dist/components/*/index.d.ts"
    },
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mordech/tokens": "^0.37.0",
    "@mordech/vite-lit-loader": "^0.37.0"
  }
}
