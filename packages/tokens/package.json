{
  "name": "@mordech/tokens",
  "author": "Elad Mordechai Mizrahi",
  "version": "0.39.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mordech/mordech-projects.git",
    "directory": "packages/tokens"
  },
  "homepage": "https://github.com/Mordech/mordech-projects/tree/main/packages/tokens#readme",
  "files": [
    "dist/**/*"
  ],
  "license": "MIT",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.ts"
      ],
      "declarations": [
        "./dist/lib/declarations/index.d.ts"
      ],
      "utils": [
        "./dist/lib/utils/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./declarations": {
      "types": "./dist/lib/declarations/index.d.ts",
      "import": "./dist/declarations/index.js"
    },
    "./utils": {
      "types": "./dist/lib/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./css": "./dist/css/index.css",
    "./css/*": "./dist/css/*"
  },
  "scripts": {
    "build:assets": "tsx scripts/index.ts",
    "build:css": "tsx scripts/bundleCss.ts",
    "build:ts": "tsx scripts/build.ts",
    "build:types": "tsc",
    "build": "run-s \"build:**\"",
    "watch:lib": "yarn build && nodemon --watch src/lib -i src/lib/styles/tokens.css --ext ts,css --exec \"yarn build\" &",
    "test": "vitest --coverage --run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:css": "stylelint 'src/**/*.{ts,css}'",
    "prepare": "yarn build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "react": "18.3.1",
    "styled-components": "^6.1.6"
  },
  "devDependencies": {
    "esbuild": "0.19.11",
    "eslint": "8.57.0",
    "stylelint": "^16.1.0",
    "tsx": "^4.0.0",
    "vitest": "1.6.0"
  }
}
